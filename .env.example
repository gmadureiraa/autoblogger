# ============================================================
# AutoBlogger — Environment Variables
# ============================================================
# Copia pra .env.local e preenche.
# Em producao, configurar no dashboard do Vercel.
# ============================================================

# --- Clerk (auth) ---
# Pegar em: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/artigos
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/artigos

# --- Database — Neon (dedicated project: autoblogger) ---
DATABASE_URL=postgresql://neondb_owner:...@ep-bitter-wildflower-...neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_REST_URL=

# --- Google Gemini (geracao de artigos) ---
# Pegar em: https://ai.google.dev
# Opcional se o usuario fornecer a propria key na UI.
GEMINI_API_KEY=

# --- Stripe (billing — opcional, ativa quando quiser) ---
# Planos: pro=$19.99/mo (50 posts), agency=$49.99/mo (200 posts)
# Price IDs são opcionais — se faltarem, checkout usa price_data inline (dev).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=https://autoblogger-rosy.vercel.app
